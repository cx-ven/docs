{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "클라우드(PMS)",
  "i18n": {
    "defaultLocale": "ko",
    "locales": ["ko", "en"]
  },
  "colors": {
    "primary": "#811fc2",
    "light": "#5306c9",
    "dark": "#3a1480"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "메뉴별 기능",
        "icon": "square-info",
        "groups": [
          {
            "group": "대시보드",
            "icon": "chalkboard",
            "pages": [
              "dashboard/login",
              "dashboard/res",
              "dashboard/roomState",
              "dashboard/roomDetail",
              "dashboard/todayGraph",
              "dashboard/his",
              "dashboard/kio",
              "dashboard/quickmenu"
            ]
          },
          {
            "group": "예약",
            "icon": "square-list",
            "pages": [
              "reservation/view",
              "reservation/createReserv",
              "reservation/list",
              "reservation/list_filter"
            ]
          },
          {
            "group": "내역",
            "icon": "credit-card",
            "pages": [
              "payment/additionalPayment",
              "payment/cancellation",
              "payment/list",
              "payment/list_filter",
              "payment/paymentSettlement",
              "payment/mileage",
              "payment/activityLog",
              "payment/coupon"
            ]
          },
          {
            "group": "프로필관리",
            "icon": "user",
            "pages": [
              "profile/customer",
              "profile/company",
              "profile/loginAccount"
            ]
          },
          {
            "group": "설정",
            "icon": "gear",
            "pages": [
              "setting/roomType",
              "setting/roomRate",
              "setting/reservation",
              "setting/kiostSet",
              "setting/SMS",
              "setting/saleNmileage",
              "setting/platformSet",
              "setting/item",
              "setting/serviceConnect",
              "setting/property"
            ]
          }
        ]
      },
      {
        "tab": "자주 묻는 기능",
        "icon": "square-question",
        "pages": [
          "dashboard/reAssign",
          "payment/checkAdditionalPayment",
          "dashboard/untitled-page"
        ]
      }
    ]
  },
  "logo": "/logo/venditLogo.svg.svg",
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
